          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "description": "Kullanıcı kayıt, giriş ve token yenileme endpoint'leri. Cookie tabanlı JWT auth kullanılır.",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const cookies = pm.response.headers.filter(h => h.key === 'set-cookie');",
                  "    cookies.forEach(c => {",
                  "        if (c.value.startsWith('accessToken=')) {",
                  "            const token = c.value.split('accessToken=')[1].split(';')[0];",
                  "            pm.collectionVariables.set('accessToken', token);",
                  "        }",
                  "    });",
                  "    pm.test('Register successful', () => {",
                  "        pm.expect(pm.response.code).to.eql(200);",
                  "        pm.expect(pm.response.json().user).to.have.property('id');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@btex.com\",\n  \"password\": \"Demo1234!\",\n  \"firstName\": \"Demo\",\n  \"lastName\": \"Kullanıcı\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Yeni bir kullanıcı kaydı oluşturur. Zod validation: email (geçerli format), password (min 6 karakter). Başarılı olursa accessToken ve refreshToken cookie'leri set edilir."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"user\": {\n    \"id\": \"uuid\",\n    \"email\": \"demo@btex.com\",\n    \"firstName\": \"Demo\",\n    \"lastName\": \"Kullanıcı\",\n    \"role\": \"CUSTOMER\",\n    \"createdAt\": \"2026-03-13T20:00:00.000Z\",\n    \"updatedAt\": \"2026-03-13T20:00:00.000Z\"\n  }\n}"
            },
            {
              "name": "Conflict – User Exists",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"error\": \"User already exists\"\n}"
            },
            {
              "name": "Validation Error",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"message\": \"Geçerli bir email adresi giriniz, Şifre en az 6 karakter olmalıdır\"\n}"
            }
          ]
        },
