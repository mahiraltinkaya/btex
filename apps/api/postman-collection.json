    {
      "name": "Booking",
      "description": "Bilet rezervasyonu, iptal ve ödeme endpoint'leri. Tüm istekler authMiddleware gerektirir. Serializable isolation ile race condition'lar engellenir. Sahiplik kontrolleri uygulanır.",
      "item": [
        {
          "name": "Reserve Ticket (Booking)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketId\": \"{{ticketId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/booking/booking",
              "host": ["{{baseUrl}}"],
              "path": ["api", "booking", "booking"]
            },
            "description": "Bir bileti RESERVED durumuna alır ve PENDING bir transaction oluşturur. Bilet OPEN durumunda olmalıdır. Serializable isolation ile double-booking engellenir."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Booking reserved\"\n}"
            },
            {
              "name": "Ticket Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"message\": \"Ticket not found\"\n}"
            },
            {
              "name": "Ticket Not Available",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"message\": \"Ticket is not available for booking\"\n}"
            },
            {
              "name": "Event Inactive",
              "status": "Gone",
              "code": 410,
              "body": "{\n  \"message\": \"Event is no longer active\"\n}"
            }
          ]
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ticketId\": \"{{ticketId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/booking/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api", "booking", "cancel"]
            },
            "description": "Rezerve edilmiş bir bileti iptal eder. Bilet OPEN'a döner ve ilgili PENDING transaction silinir. Sahiplik kontrolü uygulanır."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Booking cancelled\"\n}"
            },
            {
              "name": "Not Your Ticket",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"message\": \"You don't own this ticket\"\n}"
            },
            {
              "name": "Ticket Not Reserved",
              "status": "Conflict",
              "code": 409,
              "body": "{\n  \"message\": \"Ticket is not reserved\"\n}"
            }
          ]
        },
        {
          "name": "Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/booking/payment",
              "host": ["{{baseUrl}}"],
              "path": ["api", "booking", "payment"]
            },
            "description": "PENDING bir transaction için ödeme işlemi yapar. Bilet SOLD, transaction COMPLETED durumuna geçer. Sahiplik kontrolü uygulanır."
